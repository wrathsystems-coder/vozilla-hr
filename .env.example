# vozilla.hr environment variables
#
# Copy this file to apps/web/.env.local for local dev; Next.js and
# drizzle.config.ts both read from apps/web/.env.local. Production
# values go on Vercel project settings (encrypted).
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# === Required for boot ===

# Postgres connection.
# Local dev (Docker): postgresql://vozilla:vozilla@localhost:5432/vozilla_hr_dev
# Production (Supabase): postgresql://postgres.<project>:<pwd>@aws-0-eu-...pooler.supabase.com:6543/postgres
DATABASE_URL=XXX_DATABASE_URL

# Payload CMS secret. 32+ random characters. Generate: openssl rand -hex 32
PAYLOAD_SECRET=XXX_PAYLOAD_SECRET

# Public site URL (no trailing slash).
# Local dev: http://localhost:3000
# Production: https://vozilla.hr
NEXT_PUBLIC_SITE_URL=XXX_SITE_URL

# === Email (Resend) — Sprint 4 ===

# Resend API key. https://resend.com/api-keys
# In dev without a key, sendEmail() logs to console instead of sending.
RESEND_API_KEY=XXX_RESEND_API_KEY

# Default "from" address. Must be on a verified domain in Resend.
RESEND_FROM_EMAIL=XXX_RESEND_FROM_EMAIL

# === Bot protection (Sprint 4) ===

# Google reCAPTCHA v3. https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=XXX_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=XXX_RECAPTCHA_SECRET_KEY

# === Consent management (Sprint 2/7) ===

# Cookiebot site ID. https://manage.cookiebot.com/
NEXT_PUBLIC_COOKIEBOT_ID=XXX_COOKIEBOT_ID

# === Cron jobs (Sprint 5) ===

# Shared secret for Vercel Cron auth header. Generate: openssl rand -hex 32
CRON_SECRET=XXX_CRON_SECRET

# === Error tracking (Sprint 7) — empty disables Sentry ===

SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# === Feature-flagged off in MVP (see config/feature-flags.yml) ===

NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
